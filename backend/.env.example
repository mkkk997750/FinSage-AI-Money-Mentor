# FinSage Backend — copy to .env and fill in your values

# ── LLM ───────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here   # fallback if no Google key
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3

# ── PostgreSQL ─────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=finsage
PG_USER=postgres
PG_PASSWORD=postgres

# ── Server ────────────────────────────────────────────
PORT=8000
